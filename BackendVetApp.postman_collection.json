      ]
    },
    {
      "name": "Consultation - Management",
      "description": "Gestión de consultas: obtener estado y cerrar.",
      "item": [
        {
          "name": "Obtener Consulta",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/consultation/{{consultation_id}}",
            "description": "Obtiene una consulta completa con todos sus borradores (consultation_drafts)."
          }
        },
        {
          "name": "Cerrar Consulta - Alta",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/consultation/{{consultation_id}}/close",
            "description": "Cierra la consulta con resultado: alta del paciente.\n\nResultados válidos: discharge, hospitalization, deceased, referred",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"result\": \"discharge\",\n  \"chief_complaint\": \"Vómito y diarrea de 2 días de evolución\",\n  \"primary_diagnosis\": \"Gastroenteritis aguda\"\n}"
            }
          }
        },
        {
          "name": "Cerrar Consulta - Hospitalización",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/consultation/{{consultation_id}}/close",
            "description": "Cierra la consulta con resultado: hospitalización.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"result\": \"hospitalization\",\n  \"chief_complaint\": \"Decaimiento severo y anorexia\",\n  \"primary_diagnosis\": \"Parvovirus canino\"\n}"
            }
          }
        }
      ]
    }
  ]
}
